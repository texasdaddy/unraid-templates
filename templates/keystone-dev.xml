<?xml version="1.0"?>
<Container version="2">
  <Name>keystone-dev</Name>
  <Repository>ghcr.io/texasdaddy/keystone:dev</Repository>
  <Registry>https://github.com/texasdaddy/keystone/pkgs/container/keystone</Registry>
  <Network>br0</Network>
  <MyIP></MyIP>
  <Shell>sh</Shell>
  <Privileged>false</Privileged>
  <Support/>
  <Project>https://github.com/texasdaddy/keystone</Project>
  <Overview>Keystone (dev) — self-hosted multi-tenant personal finance platform. K0 scaffold: comes up healthy on /v1/health with NO database (degraded); fill DATABASE_URL + Core secrets when _020 Core lands. Set MyIP to a free br0 address (tape-dev is .61).</Overview>
  <Category>Network:Other</Category>
  <WebUI>http://[IP]:[PORT:8000]/v1/health</WebUI>
  <TemplateURL>https://raw.githubusercontent.com/texasdaddy/unraid-templates/main/templates/keystone-dev.xml</TemplateURL>
  <Icon>https://raw.githubusercontent.com/texasdaddy/unraid-templates/main/icons/keystone_dev.png</Icon>
  <ExtraParams/>
  <PostArgs/>
  <DateInstalled/>
  <Description>Keystone (dev) — self-hosted multi-tenant personal finance platform.</Description>
  <Config Name="HTTP Port" Target="8000" Default="8000" Mode="tcp" Description="App HTTP port" Type="Port" Display="always" Required="false" Mask="false">8000</Config>
  <Config Name="DATABASE_URL" Target="DATABASE_URL" Default="" Mode="" Description="Postgres URL (empty = degraded health-only; set at Core): postgresql+psycopg://keystone:PASSWORD@IP:5432/keystone" Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="JWT_SECRET" Target="JWT_SECRET" Default="" Mode="" Description="JWT signing key (set at Core)" Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="FILE_ENCRYPTION_KEY" Target="FILE_ENCRYPTION_KEY" Default="" Mode="" Description="Fernet key for statement encryption at rest (set at Core)" Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="KEYSTONE_API_KEYS" Target="KEYSTONE_API_KEYS" Default="" Mode="" Description="Comma-separated API keys (empty = open/dev)" Type="Variable" Display="always" Required="false" Mask="true"/>
  <Config Name="TAPE_BASE_URL" Target="TAPE_BASE_URL" Default="https://tape-dev.reinlie.com" Mode="" Description="Tape base URL (Keystone consumes Tape for market + account data)" Type="Variable" Display="always" Required="false" Mask="false">https://tape-dev.reinlie.com</Config>
  <Config Name="TAPE_API_KEY" Target="TAPE_API_KEY" Default="" Mode="" Description="X-API-Key Keystone presents to Tape" Type="Variable" Display="always" Required="false" Mask="true"/>
</Container>
